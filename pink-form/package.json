    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "mongoose": "^8.6.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "puppeteer": "^24.42.0"
  }
