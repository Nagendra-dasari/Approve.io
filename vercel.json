{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "includeFiles": "frontend/dist/**"
      }
    }
  ],
  "installCommand": "npm install",
  "buildCommand": "node build.js",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
